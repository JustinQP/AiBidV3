# Copy this file to deploy/.env for local development only.
# These are placeholders, not production credentials. Replace all passwords
# before sharing a development environment and never commit deploy/.env.

# API
API_PORT=3000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:4173
DEV_TENANT_ID=tenant-demo
MAX_UPLOAD_BYTES=26214400
DEV_PARSER_DELAY_MS=250
OBJECT_STORAGE_DRIVER=s3
OBJECT_STORAGE_TIMEOUT_MS=10000

# PostgreSQL
POSTGRES_DB=aibid
POSTGRES_USER=aibid
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_PORT=5432

# Redis (reserved for the real parser worker phase)
REDIS_PORT=6379

# S3-compatible local object storage
MINIO_ROOT_USER=aibid-local
MINIO_ROOT_PASSWORD=change-me-local-only
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_BUCKET=aibid-dev
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
