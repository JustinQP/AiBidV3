# API
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:4173

# `memory` provides a zero-dependency development/demo path.
# Use `postgres` for durable storage.
REPOSITORY_DRIVER=memory
DATABASE_URL=postgresql://aibid:change-me-local-only@localhost:5432/aibid
DATABASE_SSL=false
MIGRATE_ON_START=false

# Object storage. Keep `memory` with the default in-memory Repository. Durable
# PostgreSQL mode requires `s3`; the local Compose stack provides MinIO.
OBJECT_STORAGE_DRIVER=memory
OBJECT_STORAGE_TIMEOUT_MS=10000
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=aibid-dev
S3_ACCESS_KEY=aibid-local
S3_SECRET_KEY=change-me-local-only
S3_FORCE_PATH_STYLE=true

# Development-only tenant context. `x-tenant-id` may override this value.
# This is NOT authentication and MUST be replaced before production rollout.
DEV_TENANT_ID=tenant-demo

# Upload/parser development adapter
MAX_UPLOAD_BYTES=26214400
DEV_PARSER_DELAY_MS=250

# Durable task delivery. The API does not connect to Redis; these values are
# consumed by the independent worker in PostgreSQL mode.
REDIS_URL=redis://localhost:6379/0
REDIS_STREAM_KEY=aibid:parse-tasks
REDIS_CONSUMER_GROUP=aibid-parser
REDIS_CLAIM_IDLE_MS=60000
WORKER_ID=worker-local-1
WORKER_CONCURRENCY=2
PARSER_TIMEOUT_MS=60000
PARSER_MAX_OLD_GENERATION_SIZE_MB=256
TASK_LEASE_MS=30000
TASK_HEARTBEAT_MS=10000
TASK_MAX_ATTEMPTS=3
TASK_RETRY_BACKOFF_MS=1000
OUTBOX_POLL_INTERVAL_MS=250
OUTBOX_LEASE_MS=10000
OUTBOX_BATCH_SIZE=20
