# Keep the clickable prototype on local Mock data by default.
VITE_DATA_SOURCE=mock

# Used only when VITE_DATA_SOURCE=api or when the API client is called directly.
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_API_HEALTH_URL=http://localhost:3000/health
VITE_API_TIMEOUT_MS=15000

# Development-only tenant context. This is not an authentication mechanism.
VITE_API_TENANT_ID=dev-tenant
